// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// --- Enums ---
enum Role {
  VOLUNTEER
  MEDICAL_STAFF
  TRUSTED_PERSON
  DEVELOPER
}

enum TreatmentType {
  WORMS
  FLEAS
  EAR_MITES
  VACCINATION
}

// --- Models ---

model User {
  id                      String             @id @default(cuid())
  name                    String
  email                   String?            @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  role                    Role               @default(VOLUNTEER)
  isProfileSetupComplete  Boolean            @default(false)
  accounts                Account[]
  sessions                Session[]
  createdCats             Cat[]              @relation("Creator")
  sentMessages            Message[]          @relation("Sender")
  auditLogs               AuditLog[]
  createdInvitations      Invitation[]       @relation("CreatedBy")
  // Связь с подписками на push-уведомления
  subscriptions           PushSubscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invitation {
  id          String   @id @default(cuid())
  token       String   @unique
  expires     DateTime
  used        Boolean  @default(false)
  createdById String
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])
}

model Cat {
  id          String     @id @default(cuid())
  name        String
  avatarUrl   String?
  arrivalDate DateTime?
  birthYear   Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  notes       String?
  status      String     @default("В приюте")
  creatorId   String?
  creator     User?      @relation("Creator", fields: [creatorId], references: [id], onDelete: SetNull)
  treatments  Treatment[]
  documents   Document[]
  auditLogs   AuditLog[]
  // === НОВАЯ СВЯЗЬ С ФОТОГРАФИЯМИ ===
  photos      Photo[]
}

// === НОВАЯ МОДЕЛЬ ДЛЯ ФОТОГРАФИЙ ГАЛЕРЕИ ===
model Photo {
  id        String   @id @default(cuid())
  filePath  String
  createdAt DateTime @default(now())
  isAvatar  Boolean  @default(false)
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
}


model Treatment {
  id               String        @id @default(cuid())
  catId            String
  cat              Cat           @relation(fields: [catId], references: [id], onDelete: Cascade)
  type             TreatmentType
  date             DateTime
  productName      String
  vaccinationStage String?
  createdAt        DateTime      @default(now())
}

model Document {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  fileName  String
  filePath  String
  fileType  String
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  senderId  String
  sender    User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  change    String
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}